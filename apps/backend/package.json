{
  "name": "@middleman/backend",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter swarmd build",
    "dev": "tsx watch --exclude \"../../data/**\" --exclude \"data/**\" src/index.ts",
    "prebuild": "pnpm --filter swarmd build",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "pnpm --filter swarmd build",
    "start": "node dist/index.js",
    "pretest": "pnpm --filter swarmd build",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@google/genai": "^1.42.0",
    "@hono/node-server": "^1.19.11",
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@middleman/protocol": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "^0.34.41",
    "cron-parser": "^5.4.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8",
    "jsdom": "^27.0.1",
    "mime": "^4.1.0",
    "swarmd": "workspace:*",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
